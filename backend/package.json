{
  "name": "pothole-app-backend",
  "version": "1.0.0",
  "description": "Pothole Reporting & Tracking App Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "seed": "node scripts/seedWards.js"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.js"
    ],
    "testMatch": [
      "<rootDir>/test/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^isomorphic-dompurify$": "<rootDir>/test/mocks/isomorphic-dompurify.js",
      "^uuid$": "<rootDir>/test/mocks/uuid.js"
    },
    "clearMocks": true
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "isomorphic-dompurify": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.4",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-cron": "^4.5.0",
    "sharp": "^0.35.2",
    "twilio": "^5.2.2",
    "uuid": "^14.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
